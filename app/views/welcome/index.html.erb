<section class="relative overflow-hidden bg-white">
  <div class="absolute inset-0">
    <%= image_tag "hero-figures-bg.webp",
                  class: "h-full w-full object-cover" %>

    <!-- 左側白色漸層遮罩 -->
    <div class="absolute inset-0 bg-gradient-to-r from-white via-white/80 to-transparent"></div>
  </div>

  <div class="relative mx-auto max-w-7xl px-6 py-24 sm:py-32 lg:px-8">
    <div class="max-w-2xl">

      <h1 class="text-4xl font-extrabold tracking-tight text-gray-900 sm:text-6xl">
        <%= t("welcome.hero.title") %>
      </h1>

      <p class="mt-6 text-lg leading-8 text-gray-700">
        <%= t("welcome.hero.description") %>
      </p>

      <div class="mt-8 flex gap-4">
        <%= link_to t("welcome.hero.cta"),
                    products_path,
                    class: "rounded-xl bg-green-500 px-6 py-3 text-sm font-semibold text-white shadow-lg transition hover:bg-green-400" %>
      </div>

    </div>
  </div>
</section>
