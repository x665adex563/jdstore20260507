<div class="min-h-screen flex items-center justify-center bg-gray-50 px-4">
  <div class="w-full max-w-md rounded-2xl bg-white p-8 shadow-lg">
    <h2 class="text-center text-2xl font-bold text-gray-900">
      <%= t("devise.registrations.title") %>
    </h2>

    <p class="mt-2 text-center text-sm text-gray-500">
      <%= t("devise.registrations.subtitle") %>
    </p>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name),
          html: { class: "mt-8 space-y-5" }) do |f| %>

      <div>
        <%= f.label :email, class: "block text-sm font-medium text-gray-700" %>
        <%= f.email_field :email,
              class: "mt-1 w-full rounded-lg border border-gray-300 px-4 py-2" %>
      </div>

      <div>
        <%= f.label :password, class: "block text-sm font-medium text-gray-700" %>
        <%= f.password_field :password,
              class: "mt-1 w-full rounded-lg border border-gray-300 px-4 py-2" %>
      </div>

      <div>
        <%= f.label :password_confirmation,
              class: "block text-sm font-medium text-gray-700" %>

        <%= f.password_field :password_confirmation,
              class: "mt-1 w-full rounded-lg border border-gray-300 px-4 py-2" %>
      </div>

      <%= f.submit t("devise.registrations.create_account"),
            class: "w-full rounded-lg bg-blue-600 px-4 py-2 font-semibold text-white hover:bg-blue-700" %>
    <% end %>

    <div class="mt-6 text-center text-sm text-gray-500">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
