<div class="relative inline-block group">
  <!-- Button -->
  <div class="inline-flex items-center gap-2 rounded-lg bg-gray-100 px-3 py-2 text-sm font-medium text-gray-800 cursor-pointer hover:bg-gray-200">
    <span>
      <%= I18n.locale == :en ? "EN" : "中文" %>
    </span>

    <svg class="h-4 w-4 transition-transform group-hover:rotate-180"
         fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M19 9l-7 7-7-7" />
    </svg>
  </div>

  <!-- Dropdown -->
  <div class="absolute right-0 z-50 mt-2 w-32 rounded-lg border bg-white shadow-lg
              opacity-0 invisible group-hover:visible group-hover:opacity-100
              transition-all duration-150">
    <%= link_to url_for(locale: :en, only_path: true),
        class: "block px-4 py-2 text-sm hover:bg-gray-100 #{'bg-gray-50 font-bold' if I18n.locale == :en}" do %>
      English
    <% end %>

    <%= link_to url_for(locale: :"zh-TW", only_path: true),
        class: "block px-4 py-2 text-sm hover:bg-gray-100 #{'bg-gray-50 font-bold' if I18n.locale == :"zh-TW"}" do %>
      中文
    <% end %>
  </div>
</div>
