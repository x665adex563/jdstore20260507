<nav class="bg-slate-900 shadow-sm">
  <div class="flex h-16 items-center justify-between">

    <!-- Left: Brand -->
    <div class="flex items-center">
      <%= link_to root_path,
          class: "flex h-16 items-center bg-green-500 px-8 text-2xl font-extrabold tracking-tight text-white transition hover:bg-green-400" do %>
        JDStore
      <% end %>

      <!-- Products -->
      <%= link_to products_path,
          class: "flex h-16 items-center px-6 text-sm font-semibold text-gray-300 transition hover:bg-slate-800 hover:text-white" do %>
        <i class="fa-solid fa-box mr-1"></i>
        <%= t("navbar.products") %>
      <% end %>
    </div>


    <!-- Right: Auth actions -->
    <div class="flex items-center gap-3">

      <!-- Cart -->
      <%= link_to carts_path,
          class: "relative flex items-center text-sm font-medium text-gray-300 transition hover:text-white" do %>

        <i class="fa-solid fa-cart-shopping mr-1"></i>
        <span><%= t("navbar.cart") %></span>

        <% if current_cart.cart_items.any? %>
          <span class="ml-2 inline-flex items-center justify-center rounded-full bg-red-500 px-2 py-0.5 text-xs font-semibold text-white">
            <%= current_cart.cart_items.sum(:quantity) %>
          </span>
        <% end %>

      <% end %>

      <%= render "shared/locale_switcher" %>

      <% if user_signed_in? %>
        <% if current_user.admin? %>
          <%= render "shared/navbar_admin" %>
        <% else %>
          <%= render "shared/navbar_user" %>
        <% end %>
      <% else %>
        <%= render "shared/navbar_guest" %>
      <% end %>
    </div>
  </div>
</nav>
