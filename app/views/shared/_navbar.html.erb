<nav class="bg-slate-900 shadow-sm">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">

      <!-- Left: Brand -->
      <div class="flex items-center space-x-6">
        <%= link_to root_path, class: "text-xl font-semibold tracking-tight text-white" do %>
          JDStore
        <% end %>

        <!-- Products -->
        <%= link_to products_path,
            class: "text-sm font-medium text-gray-300 transition hover:text-white" do %>
          <i class="fa-solid fa-box mr-1"></i>
          <%= t("navbar.products") %>
        <% end %>
      </div>


      <!-- Right: Auth actions -->
      <div class="flex items-center">
        <%= render "shared/locale_switcher" %>

        <% if user_signed_in? %>
          <% if current_user.admin? %>
            <%= render "shared/navbar_admin" %>
          <% else %>
            <%= render "shared/navbar_user" %>
          <% end %>
        <% else %>
          <%= render "shared/navbar_guest" %>
        <% end %>
      </div>

    </div>
  </div>
</nav>
