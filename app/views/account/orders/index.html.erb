<div class="container mx-auto px-4 py-8">
  <div class="mx-auto max-w-5xl space-y-6">

    <div class="flex items-center justify-between">
      <h2 class="text-2xl font-bold text-gray-900">
        <%= t("account_orders.index.title") %>
      </h2>
    </div>

    <div class="overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm">
      <% if @orders.any? %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="w-32 px-6 py-4 text-left text-sm font-semibold text-gray-700">
                  <%= t("account_orders.index.table.order_number") %>
                </th>
                <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">
                  <%= t("account_orders.index.table.created_at") %>
                </th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 bg-white">
              <% @orders.each do |order| %>
                <tr class="transition hover:bg-gray-50">
                  <td class="px-6 py-4 text-sm">
                    <%= link_to order_path(order),
                        class: "font-medium text-red-500 hover:text-red-600 hover:underline" do %>
                      #<%= order.id %>
                    <% end %>
                  </td>

                  <td class="px-6 py-4 text-sm text-gray-600">
                    <%= l(order.created_at, format: :long) %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="px-6 py-12 text-center">
          <p class="text-sm text-gray-500">
            <%= t("account_orders.index.empty") %>
          </p>
        </div>
      <% end %>
    </div>

  </div>
</div>
