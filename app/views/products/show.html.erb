<div class="mx-auto max-w-5xl px-4 py-8">
  <div class="grid grid-cols-1 gap-8 md:grid-cols-2">

    <!-- 左：圖片 -->
    <div>
      <% if @product.image.attached? %>
        <%= image_tag @product.image,
            class: "w-full rounded-2xl border border-gray-200 object-cover shadow-sm" %>
      <% else %>
        <div class="flex aspect-square w-full items-center justify-center rounded-2xl border border-gray-200 bg-gray-100 shadow-sm">
          <div class="text-center text-gray-400">
            <i class="fa-regular fa-image mb-3 text-5xl"></i>
            <p class="text-sm"><%= t("products.no_pic") %></p>
          </div>
        </div>
      <% end %>
    </div>

    <!-- 右：商品資訊 -->
    <div class="flex flex-col justify-between">
      <div>
        <h2 class="text-2xl font-semibold text-gray-900">
          <%= @product.title %>
        </h2>

        <div class="mt-4 h-24 overflow-hidden text-gray-600">
          <p><%= @product.description %></p>
        </div>

        <div class="mt-4 flex items-center gap-2 text-sm text-gray-500">
          <i class="fa-solid fa-box-open text-gray-400"></i>
          <span><%= t(".quantity") %>：<%= @product.quantity %></span>
        </div>

        <div class="mt-3 flex items-center gap-2 text-2xl font-bold text-red-500">
          <%= number_to_currency(@product.price, unit: t("currency.unit"), precision: 0) %>
        </div>
      </div>

      <div class="mt-6">
        <% if @product.quantity > 0 %>
          <%= button_to cart_items_path(product_id: @product.id),
              class: "flex w-full items-center justify-center gap-2 rounded-xl bg-red-500 px-6 py-3 font-medium text-white shadow-sm transition hover:bg-red-600" do %>
            <i class="fa-solid fa-cart-shopping"></i>
            <span><%= t("cart_items.add_to_cart") %></span>
          <% end %>
        <% else %>
          <div class="rounded-xl border border-gray-200 bg-gray-50 px-6 py-3 text-center text-sm text-gray-500">
            <i class="fa-solid fa-circle-exclamation mr-2"></i>
            <%= t("products.sold_out") %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
