<div style="margin:0; padding:0; background-color:#f3f4f6;">
  <table width="100%" style="background-color:#f3f4f6; padding:24px 0;">
    <tr>
      <td align="center">

        <table width="600" style="background:#ffffff; border:1px solid #e5e7eb; border-radius:12px;">

          <!-- Header -->
          <tr>
            <td style="padding:32px; border-bottom:1px solid #e5e7eb;">
              <div style="font-size:22px; font-weight:bold; color:#111827; margin-bottom:12px;">
                <%= t("order_mailer.notify_ship.title") %>
              </div>

              <div style="font-size:14px; color:#6b7280; margin-bottom:16px;">
                <%= t("order_mailer.notify_ship.description") %>
              </div>

              <a href="<%= order_url(token: @order.token, locale: I18n.locale) %>"
                 style="display:inline-block; padding:10px 16px; background:#2563eb; color:#fff; text-decoration:none; border-radius:8px;">
                <%= t("order_mailer.notify_ship.cta") %>
              </a>
            </td>
          </tr>

          <!-- Order Details -->
          <%= render "order_details" %>

        </table>

      </td>
    </tr>
  </table>
</div>
