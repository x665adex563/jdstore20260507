<%= form_with model: [:admin, @product], local: true do |f| %>

  <% if @product.errors.any? %>
    <div class="mb-4 text-red-600">
      <ul>
        <% @product.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- Title -->
  <div class="mb-4">
    <%= f.label :title, t("activerecord.attributes.product.title"), class: "block text-gray-700 font-medium mb-1" %>
    <%= f.text_field :title, class: "w-full border rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
  </div>

  <!-- Description -->
  <div class="mb-4">
    <%= f.label :description, t("activerecord.attributes.product.description"), class: "block text-gray-700 font-medium mb-1" %>
    <%= f.text_area :description, class: "w-full border rounded px-3 py-2 h-24 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
  </div>

  <!-- Quantity -->
  <div class="mb-4">
    <%= f.label :quantity, t("activerecord.attributes.product.quantity"), class: "block text-gray-700 font-medium mb-1" %>
    <%= f.number_field :quantity, class: "w-full border rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
  </div>

  <!-- Price -->
  <div class="mb-6">
    <%= f.label :price, t("activerecord.attributes.product.price"), class: "block text-gray-700 font-medium mb-1" %>
    <%= f.number_field :price, step: 1, class: "w-full border rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
  </div>


  <!-- Image Upload -->
  <div class="mb-6" data-controller="image-preview">
    <%= f.label :image,
        t("activerecord.attributes.product.image"),
        class: "mb-2 block text-sm font-medium text-gray-700" %>

    <div class="mb-4">
      <div class="overflow-hidden rounded-2xl border border-dashed border-gray-300 bg-gray-50">

        <% if @product.image.attached? %>

          <img
            data-image-preview-target="preview"
            src="<%= url_for(@product.image) %>"
            alt="<%= t('admin.products.form.image_preview_alt') %>"
            class="block h-64 w-full object-contain"
          >

          <div
            data-image-preview-target="placeholder"
            class="hidden h-64 w-full items-center justify-center"
          >
            <div class="text-center text-gray-400">
              <i class="fa-regular fa-image mb-3 text-4xl"></i>

              <p class="text-sm font-medium">
                <%= t("admin.products.form.no_image") %>
              </p>
            </div>
          </div>

        <% else %>

          <img
            data-image-preview-target="preview"
            src=""
            alt="<%= t('admin.products.form.image_preview_alt') %>"
            class="hidden h-64 w-full object-contain"
          >

          <div
            data-image-preview-target="placeholder"
            class="flex h-64 w-full items-center justify-center"
          >
            <div class="text-center text-gray-400">
              <i class="fa-regular fa-image mb-3 text-4xl"></i>

              <p class="text-sm font-medium">
                <%= t("admin.products.form.no_image") %>
              </p>
            </div>
          </div>

        <% end %>

      </div>
    </div>

    <%= f.file_field :image,
        accept: "image/*",
        class: "block w-full rounded-xl border border-gray-300 bg-white px-3 py-2 text-sm text-gray-700
                file:mr-4 file:rounded-lg file:border-0 file:bg-gray-100 file:px-4 file:py-2
                file:text-sm file:font-medium file:text-gray-700 hover:file:bg-gray-200",
        data: {
          action: "change->image-preview#change"
        } %>

    <p class="mt-2 text-xs text-gray-500">
      <%= t("admin.products.form.image_hint") %>
    </p>
  </div>


  <!-- Submit Button -->
  <div>
    <%= f.submit submit_label,
    data: { disable_with: t("common.submitting") },
    class: "bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
  </div>
<% end %>
