<div class="overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm">
  <!-- Header -->
  <div class="flex items-center justify-between border-b border-gray-200 px-6 py-4">
    <h2 class="text-xl font-semibold text-gray-900">
      <%= t("admin.products.index.title") %>
    </h2>

    <%= link_to new_admin_product_path,
        class: "inline-flex items-center rounded-lg bg-slate-900 px-4 py-2 text-sm font-medium text-white transition hover:bg-slate-800" do %>
      <i class="fa-solid fa-plus mr-2"></i>
      <%= t("admin.products.index.new") %>
    <% end %>
  </div>

  <!-- Table -->
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">
            #
          </th>
          <th class="w-[220px] px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">
            <%= t("admin.products.index.product_pic") %>
          </th>
          <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">
            <%= t("admin.products.index.name") %>
          </th>
          <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">
            <%= t("admin.products.index.price") %>
          </th>
          <th class="w-[260px] px-6 py-3 text-xs font-semibold tracking-wider text-gray-500">
            <div class="flex justify-center">
              <%= t("admin.products.index.options") %>
            </div>
          </th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100 bg-white">
        <% @products.each do |product| %>
          <tr class="hover:bg-gray-50">
            <td class="whitespace-nowrap px-6 py-4 text-sm text-gray-700">
              <%= product.id %>
            </td>
            <td class="px-6 py-4">
              <%= link_to product_path(product), class: "block w-fit" do %>
                <% if product.image.attached? %>
                  <%= image_tag product.image,
                      class: "h-20 w-20 rounded-lg border border-gray-200 object-cover" %>
                <% else %>
                  <%= image_tag "https://placehold.co/200x200?text=No+Pic",
                      class: "h-20 w-20 rounded-lg border border-gray-200 object-cover" %>
                <% end %>
              <% end %>
            </td>
            <td class="px-6 py-4 text-sm font-medium text-gray-900">
              <%= product.title %>
            </td>

            <td class="px-6 py-4 text-sm text-gray-700">
              <%= number_to_currency(product.price, unit: t("currency.unit"), precision: 0) %>
            </td>

            <td class="w-[260px] whitespace-nowrap px-6 py-4 text-sm">
              <div class="flex items-center justify-center gap-2 whitespace-nowrap">
                <%= link_to edit_admin_product_path(product),
                    class: "inline-flex items-center whitespace-nowrap rounded-md border border-gray-300 px-3 py-1.5 text-sm font-medium text-gray-700 transition hover:bg-gray-100" do %>
                  <i class="fa-regular fa-pen-to-square mr-2"></i>
                  <%= t("admin.products.index.edit") %>
                <% end %>

                <%= link_to admin_product_path(product),
                    data: {
                      turbo_method: :delete,
                      turbo_confirm: t("admin.products.confirm.delete")
                    },
                    class: "inline-flex items-center whitespace-nowrap rounded-md border border-red-300 px-3 py-1.5 text-sm font-medium text-red-600 transition hover:bg-red-50" do %>
                  <i class="fa-regular fa-trash-can mr-2"></i>
                  <%= t("admin.products.index.delete") %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
