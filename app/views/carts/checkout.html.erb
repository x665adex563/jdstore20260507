<div class="container mx-auto px-4 py-8">
  <section class="mb-10">
    <h2 class="mb-4 text-2xl font-bold text-gray-900">
      <%= t("carts.cart_details") %>
    </h2>

    <div class="overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="w-4/5 px-4 py-3 text-left text-sm font-semibold text-gray-600">
                <%= t("carts.table.product_info") %>
              </th>
              <th class="px-4 py-3 text-left text-sm font-semibold text-gray-600">
                <%= t("carts.table.price") %>
              </th>
              <th class="px-4 py-3 text-left text-sm font-semibold text-gray-600">
                <%= t("carts.table.quantity") %>
              </th>
            </tr>
          </thead>

          <tbody class="divide-y divide-gray-100 bg-white">
            <% current_cart.cart_items.each do |cart_item| %>
              <tr class="hover:bg-gray-50">
                <td class="px-4 py-4 text-sm text-gray-800">
                  <%= link_to cart_item.product.title,
                      product_path(cart_item.product),
                      class: "font-medium text-slate-900 hover:text-red-500 hover:underline" %>
                </td>

                <td class="px-4 py-4 text-sm text-gray-700">
                  <%= number_to_currency(cart_item.product.price, unit: t("currency.unit"), precision: 0) %>
                </td>

                <td class="px-4 py-4 text-sm text-gray-700">
                  <%= cart_item.quantity %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <div class="flex justify-end border-t border-gray-200 bg-gray-50 px-4 py-4">
        <p class="text-base font-semibold text-gray-800">
          <%= t("carts.total") %>
          <span class="ml-2 text-lg text-red-600">
            <%= number_to_currency(render_cart_total_price(current_cart), unit: t("currency.unit"), precision: 0) %>
          </span>
        </p>
      </div>
    </div>
  </section>

  <section>
    <h2 class="mb-4 text-2xl font-bold text-gray-900">
      <%= t("carts.order_info") %>
    </h2>

    <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
      <%= form_with model: @order, class: "space-y-8" do |f| %>
        <fieldset class="space-y-4">
          <legend class="text-lg font-semibold text-gray-900">
            <%= t("carts.orderer") %>
          </legend>

          <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
            <div>
              <%= f.label :billing_name, t("orders.form.billing_name"), class: "mb-2 block text-sm font-medium text-gray-700" %>
              <%= f.text_field :billing_name,
                  class: "w-full rounded-lg border px-3 py-2 text-gray-900 shadow-sm focus:outline-none focus:ring-2 #{ @order.errors[:billing_name].any? ? 'border-red-500 focus:border-red-500 focus:ring-red-200' : 'border-gray-300 focus:border-red-500 focus:ring-red-200' }" %>
              <% if @order.errors[:billing_name].any? %>
                <p class="mt-1 text-sm text-red-600">
                  <%= @order.errors[:billing_name].first %>
                </p>
              <% end %>
            </div>
            <div>
              <%= f.label :billing_address, t("orders.form.billing_address"), class: "mb-2 block text-sm font-medium text-gray-700" %>
              <%= f.text_field :billing_address,
                  class: "w-full rounded-lg border px-3 py-2 text-gray-900 shadow-sm focus:outline-none focus:ring-2 #{ @order.errors[:billing_address].any? ? 'border-red-500 focus:border-red-500 focus:ring-red-200' : 'border-gray-300 focus:border-red-500 focus:ring-red-200' }" %>
              <% if @order.errors[:billing_address].any? %>
                <p class="mt-1 text-sm text-red-600">
                  <%= @order.errors[:billing_address].first %>
                </p>
              <% end %>
            </div>
          </div>
        </fieldset>

        <fieldset class="space-y-4">
          <legend class="text-lg font-semibold text-gray-900">
            <%= t("carts.receiver") %>
          </legend>

          <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
            <div>
              <%= f.label :shipping_name, t("orders.form.shipping_name"), class: "mb-2 block text-sm font-medium text-gray-700" %>
              <%= f.text_field :shipping_name,
                  class: "w-full rounded-lg border px-3 py-2 text-gray-900 shadow-sm focus:outline-none focus:ring-2 #{ @order.errors[:shipping_name].any? ? 'border-red-500 focus:border-red-500 focus:ring-red-200' : 'border-gray-300 focus:border-red-500 focus:ring-red-200' }" %>
              <% if @order.errors[:shipping_name].any? %>
                <p class="mt-1 text-sm text-red-600">
                  <%= @order.errors[:shipping_name].first %>
                </p>
              <% end %>
            </div>
            <div>
              <%= f.label :shipping_address, t("orders.form.shipping_address"), class: "mb-2 block text-sm font-medium text-gray-700" %>
              <%= f.text_field :shipping_address,
                  class: "w-full rounded-lg border px-3 py-2 text-gray-900 shadow-sm focus:outline-none focus:ring-2 #{ @order.errors[:shipping_address].any? ? 'border-red-500 focus:border-red-500 focus:ring-red-200' : 'border-gray-300 focus:border-red-500 focus:ring-red-200' }" %>
              <% if @order.errors[:shipping_address].any? %>
                <p class="mt-1 text-sm text-red-600">
                  <%= @order.errors[:shipping_address].first %>
                </p>
              <% end %>
            </div>
          </div>
        </fieldset>

        <div class="flex justify-end">
          <%= f.submit t("carts.submit_order"),
              data: { disable_with: t("common.submitting") },
              class: "inline-flex items-center rounded-lg bg-red-500 px-6 py-3 font-semibold text-white shadow-sm transition hover:bg-red-600" %>
        </div>
      <% end %>
    </div>
  </section>
</div>
